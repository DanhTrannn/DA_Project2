# PostgreSQL source database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SOURCE_DATABASE=Adventureworks

# Optional host identity for Linux bind mounts
HOST_UID=1000
HOST_GID=1000

# Optional AdventureWorksDW service
DW_DATABASE=AdventureworksDW
DW_PORT=5433

# Service ports
DBT_DOCS_PORT=8081
MLFLOW_PORT=5000
PREFECT_PORT=4200
SUPERSET_PORT=8088

# Superset local account
SUPERSET_SECRET_KEY=replace-with-a-random-secret
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=change-me
