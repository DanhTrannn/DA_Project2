left join "Adventureworks"."analytics_work_staging"."stg_person" p
    on c.person_id = p.business_entity_id
left join "Adventureworks"."analytics_work_staging"."stg_store" s
    on c.store_id = s.business_entity_id
left join "Adventureworks"."analytics_work_staging"."stg_sales_territory" t
    using (territory_id)
  );
  
