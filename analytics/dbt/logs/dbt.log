  create  table "Adventureworks"."analytics_work_audit"."source_to_dw_reconciliation__dbt_tmp"
  
  
    as
  
  (
    with metric_values as (
    select
        'sales_order_count'::text as metric_name,
        (select count(*)::numeric from "Adventureworks"."analytics_work_staging"."stg_sales_order_header") as source_value,
        (select count(*)::numeric from "Adventureworks"."analytics_work_core_dw"."fact_sales_order") as dw_value,
        0::numeric as tolerance

    union all

    select
        'sales_line_count',
        (select count(*)::numeric from "Adventureworks"."analytics_work_staging"."stg_sales_order_detail"),
        (select count(*)::numeric from "Adventureworks"."analytics_work_core_dw"."fact_sales_order_line"),
        0::numeric

    union all

    select
        'sales_line_revenue',
        (select round(sum(line_total)::numeric, 2) from "Adventureworks"."analytics_work_staging"."stg_sales_order_detail"),
        (select round(sum(net_sales)::numeric, 2) from "Adventureworks"."analytics_work_core_dw"."fact_sales_order_line"),
        0.01::numeric

    union all

    select
        'header_subtotal_vs_detail',
        (select round(sum(subtotal)::numeric, 2) from "Adventureworks"."analytics_work_staging"."stg_sales_order_header"),
        (select round(sum(net_sales)::numeric, 2) from "Adventureworks"."analytics_work_core_dw"."fact_sales_order_line"),
        0.01::numeric
)

select
    metric_name,
    source_value,
    dw_value,
    dw_value - source_value as difference,
    case when source_value = 0 then null
         else (dw_value - source_value) / source_value
    end as difference_pct,
    tolerance,
    case when abs(dw_value - source_value) <= tolerance then 'PASS' else 'FAIL' end as status,
    current_timestamp as checked_at
from metric_values
  );
  
[0m09:30:53.240734 [debug] [Thread-2 (]: On model.adventureworks_analytics.sales_monthly_kpi: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "adventureworks_analytics", "target_name": "dev", "node_id": "model.adventureworks_analytics.sales_monthly_kpi"} */

  
    

  create  table "Adventureworks"."analytics_work_mart_sales"."sales_monthly_kpi__dbt_tmp"
  
  
    as
  
  (
    with monthly as (
    select
        date_trunc('month', f.order_date)::date as month,
        f.country_code,
        f.geography_key as territory_id,
        count(distinct f.sales_order_id) as order_count,
        count(*) as sales_line_count,
        sum(f.order_quantity) as quantity_sold,
        sum(f.gross_sales) as gross_sales,
        sum(f.discount_amount) as discount_amount,
        sum(f.net_sales) as revenue,
        sum(f.estimated_cogs) as estimated_cogs,
        sum(f.estimated_gross_profit) as estimated_gross_profit,
        case when sum(f.net_sales) = 0 then null
             else sum(f.estimated_gross_profit) / sum(f.net_sales)
        end as estimated_gross_margin_pct,
        sum(f.loss_amount) as loss_amount,
        count(*) filter (where f.is_loss_line) as loss_line_count,
        count(*) filter (where f.is_loss_line)::numeric / nullif(count(*), 0) as loss_line_rate,
        sum(f.net_sales) / nullif(count(distinct f.sales_order_id), 0) as average_order_value
    from "Adventureworks"."analytics_work_core_dw"."fact_sales_order_line" f
    group by 1, 2, 3
)

select
    *,
    revenue - lag(revenue) over (
        partition by country_code, territory_id order by month
    ) as revenue_change,
    case
        when lag(revenue) over (
            partition by country_code, territory_id order by month
        ) = 0 then null
        else revenue / lag(revenue) over (
            partition by country_code, territory_id order by month
        ) - 1
    end as revenue_growth_pct
from monthly
  );
  
