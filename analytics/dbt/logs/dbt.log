    max(order_date) as data_end_date,
    count(distinct sales_order_id) as order_count,
    count(*) as sales_line_count,
    sum(order_quantity) as quantity_sold,
    sum(net_sales) as revenue,
    sum(estimated_cogs) as estimated_cogs,
