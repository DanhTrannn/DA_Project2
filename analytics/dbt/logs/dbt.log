  create  table "Adventureworks"."mart_finance"."management_pnl_summary__dbt_tmp"
  
  
    as
  
  (
    with totals as (
    select
        sum(revenue) as revenue,
        sum(estimated_cogs) as estimated_cogs,
        sum(estimated_gross_profit) as estimated_gross_profit,
