  create  table "Adventureworks"."analytics_work_analytics"."feature_monthly_sales__dbt_tmp"
  
  
    as
  
  (
    select
    month,
    order_count,
    quantity_sold as quantity,
    revenue,
    estimated_cogs,
    estimated_gross_profit,
    estimated_gross_margin_pct
from "Adventureworks"."analytics_work_mart_sales_forecast"."monthly_sales_series"
